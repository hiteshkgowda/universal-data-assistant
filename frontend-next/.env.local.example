# Copy to .env.local and adjust values. Never commit .env.local.

# The FastAPI backend URL. Frontend fetches all API data from here.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# NEXTAUTH_URL must exactly match the origin the app is served from.
# NextAuth builds the Google redirect URI as:
#   ${NEXTAUTH_URL}/api/auth/callback/google
# That exact URI must be listed in Google Cloud Console → Authorized redirect URIs.
#
# Local dev:   NEXTAUTH_URL=http://localhost:3000
# Production:  NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Random secret for NextAuth session encryption. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# ---------------------------------------------------------------------------
# Google OAuth credentials
# ---------------------------------------------------------------------------
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Credential type: OAuth 2.0 Client ID (Application type: Web application)
#
# Required in Google Console — Authorized JavaScript origins:
#   http://localhost:3000
#   https://your-app.vercel.app            ← production
#
# Required in Google Console — Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://your-app.vercel.app/api/auth/callback/google   ← production
#
# The redirect_uri NextAuth sends to Google is always:
#   ${NEXTAUTH_URL}/api/auth/callback/google
# If Google rejects it with "Error 400: redirect_uri_mismatch", the URI above
# is not in the Authorized redirect URIs list in the Console.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ---------------------------------------------------------------------------
# Backend JWT (shared secret — must match BACKEND_JWT_SECRET in root .env)
# ---------------------------------------------------------------------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BACKEND_JWT_SECRET=change-me-use-openssl-rand-base64-32
