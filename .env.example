# DataPilot AI — environment configuration
# Copy this file to ".env" and adjust values as needed:
#   cp .env.example .env

# --- Application ---
APP_NAME=DataPilot AI
APP_ENV=development

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- File uploads ---
# Directory where uploaded datasets and their metadata are stored.
UPLOAD_DIR=uploads
# Maximum accepted upload size, in megabytes.
MAX_UPLOAD_SIZE_MB=50

# --- Frontend ---
# Base URL the Streamlit app uses to reach the FastAPI backend.
BACKEND_URL=http://localhost:8000

# --- LLM provider (Ollama / Llama 3) ---
# Base URL of the local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434
# Model tag to use for query planning (must be pulled: `ollama pull llama3`).
OLLAMA_MODEL=llama3
# Timeout, in seconds, for a single planning request.
OLLAMA_TIMEOUT_SECONDS=60

# --- In-memory caches (per process) ---
# Max number of parsed DataFrames kept in memory (LRU eviction).
DATAFRAME_CACHE_MAX_ENTRIES=8
# Max number of derived dataset schemas kept in memory (LRU eviction).
SCHEMA_CACHE_MAX_ENTRIES=32

# --- Visualization ---
# Max number of points sampled for a scatter (xy_select) chart.
SCATTER_MAX_POINTS=1000

# --- Reporting ---
# Directory where generated PDF reports and their metadata are stored.
REPORTS_DIR=reports
# Report format version, recorded in each report's metadata.
REPORT_VERSION=1.0

# --- Database connectivity ---
# Directory where saved connection definitions are stored.
CONNECTIONS_DIR=connections
# Fernet key used to encrypt stored DB passwords. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, only passwordless connections (e.g. SQLite) can be saved.
DB_ENCRYPTION_KEY=
# Max rows loaded from a table into memory for analysis.
DB_MAX_ROWS=25000
# Seconds a database-backed table frame is cached before reloading.
DB_CACHE_TTL_SECONDS=60
# SQLAlchemy connection pool size per engine.
DB_POOL_SIZE=5
# Connection timeout (seconds) for PostgreSQL/MySQL.
DB_CONNECT_TIMEOUT_SECONDS=10
# Push supported aggregates down to SQL (full-table) instead of loading pandas.
DB_PUSHDOWN_ENABLED=true

# --- Authentication ---
# Shared HS256 secret used to verify JWTs issued by the Next.js frontend.
# Must match BACKEND_JWT_SECRET in frontend-next/.env.local. Generate with:
#   openssl rand -base64 32
BACKEND_JWT_SECRET=

# --- Forecasting ---
# Maximum number of future periods a forecast may project.
MAX_FORECAST_HORIZON=36
# Default horizon when the request/plan does not specify one.
FORECAST_DEFAULT_HORIZON=12
# Minimum data points before a full model is attempted (else it degrades).
FORECAST_MIN_POINTS=6
# Robust-z threshold (in MADs) for flagging anomalies.
ANOMALY_SENSITIVITY=3.0
# Include a forecast section in PDF reports (only if a target column is set).
FORECAST_IN_REPORTS=true
# Explicit columns for the report forecast. If FORECAST_TARGET_COLUMN is blank,
# no forecast section is added to reports (no automatic column selection).
FORECAST_DATE_COLUMN=
FORECAST_TARGET_COLUMN=
# Resample frequency (D, W, M, Q, Y) and aggregation (sum, mean) for reports.
FORECAST_FREQUENCY=M
FORECAST_AGGREGATION=sum
